{
  "name": "ParcelOps",
  "options": {
    "bundleIdPrefix": "app.bitrig.parcelops",
    "deploymentTarget": {
      "iOS": "18.0",
      "macOS": "15.0",
      "watchOS": "11.0"
    }
  },
  "settings": {
    "base": {
      "SWIFT_VERSION": "5.0"
    }
  },
  "packages": {
    "MSAL": {
      "url": "https://github.com/AzureAD/microsoft-authentication-library-for-objc.git",
      "exactVersion": "2.12.1"
    },
    "GoogleSignIn": {
      "url": "https://github.com/google/GoogleSignIn-iOS.git",
      "exactVersion": "9.2.0"
    }
  },
  "targets": {
    "ParcelOps": {
      "type": "application",
      "supportedDestinations": [
        "iOS",
        "macOS"
      ],
      "sources": [
        {
          "path": "Sources"
        },
        {
          "path": "Shared"
        },
        {
          "path": "App/Assets.xcassets"
        }
      ],
      "dependencies": [
        {
          "package": "MSAL",
          "product": "MSAL"
        },
        {
          "package": "GoogleSignIn",
          "product": "GoogleSignIn"
        },
        {
          "embed": true,
          "target": "ParcelOps Widget Extension",
          "destinationFilters": [
            "iOS"
          ]
        }
      ],
      "info": {
        "path": "App/Info.plist",
        "properties": {
          "UILaunchScreen": {
            "UIColorName": "LaunchBackground"
          },
          "NSSupportsLiveActivities": true,
          "NSSupportsLiveActivitiesFrequentUpdates": true,
          "LSApplicationCategoryType": "public.app-category.business",
          "CFBundleURLTypes": [
            {
              "CFBundleURLName": "Microsoft 365 OAuth callback",
              "CFBundleURLSchemes": [
                "msauth.app.bitrig.parcelops"
              ]
            },
            {
              "CFBundleURLName": "Gmail OAuth callback placeholder",
              "CFBundleURLSchemes": [
                "com.googleusercontent.apps.parcelops-placeholder"
              ]
            }
          ],
          "LSApplicationQueriesSchemes": [
            "msauthv2",
            "msauthv3",
            "googlechrome",
            "comgooglemaps"
          ],
          "GIDClientID": "GMAIL_CLIENT_ID_PLACEHOLDER_REPLACE_BEFORE_REAL_SIGN_IN"
        }
      },
      "entitlements": {
        "path": "App/App.entitlements",
        "properties": {
          "com.apple.security.app-sandbox": true,
          "com.apple.security.network.client": true,
          "keychain-access-groups": [
            "$(AppIdentifierPrefix)com.microsoft.adalcache",
            "$(AppIdentifierPrefix)com.microsoft.identity.universalstorage"
          ]
        }
      },
      "settings": {
        "base": {
          "ASSETCATALOG_COMPILER_APPICON_NAME": "AppIcon",
          "ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME": "AccentColor",
          "ENABLE_DEBUG_DYLIB": "NO",
          "LD_RUNPATH_SEARCH_PATHS": [
            "$(inherited)",
            "@executable_path/Frameworks",
            "@executable_path/../Frameworks"
          ],
          "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.parcelops",
          "TARGETED_DEVICE_FAMILY": "1,2"
        }
      }
    },
    "ParcelOps Watch": {
      "type": "application",
      "platform": "watchOS",
      "sources": [
        {
          "path": "Watch"
        },
        {
          "path": "Watch/Assets.xcassets"
        }
      ],
      "info": {
        "path": "Watch/Info.plist",
        "properties": {
          "WKApplication": true,
          "WKWatchOnly": true
        }
      },
      "settings": {
        "base": {
          "ASSETCATALOG_COMPILER_APPICON_NAME": "AppIcon",
          "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.parcelops.watch"
        }
      }
    },
    "ParcelOps Widget Extension": {
      "type": "app-extension",
      "platform": "iOS",
      "sources": [
        {
          "path": "Widget Extension"
        },
        {
          "path": "Shared"
        }
      ],
      "info": {
        "path": "Widget Extension/Info.plist",
        "properties": {
          "CFBundleDisplayName": "ParcelOps Widget Extension",
          "NSExtension": {
            "NSExtensionPointIdentifier": "com.apple.widgetkit-extension"
          }
        }
      },
      "settings": {
        "base": {
          "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.parcelops.widget-extension"
        }
      }
    },
    "ParcelOpsTests": {
      "type": "bundle.unit-test",
      "platform": "macOS",
      "sources": [
        {
          "path": "Tests/ParcelOpsTests"
        }
      ],
      "dependencies": [
        {
          "target": "ParcelOps"
        }
      ],
      "settings": {
        "base": {
          "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.parcelops.tests",
          "TEST_HOST": "$(BUILT_PRODUCTS_DIR)/ParcelOps.app/Contents/MacOS/ParcelOps",
          "BUNDLE_LOADER": "$(TEST_HOST)"
        }
      }
    }
  },
  "schemes": {
    "ParcelOps": {
      "build": {
        "targets": {
          "ParcelOps": "all"
        }
      },
      "test": {
        "targets": [
          "ParcelOpsTests"
        ]
      },
      "run": {
        "config": "Debug"
      },
      "archive": {
        "config": "Release"
      }
    },
    "ParcelOps Watch": {
      "build": {
        "targets": {
          "ParcelOps Watch": "all"
        }
      },
      "run": {
        "config": "Debug"
      },
      "archive": {
        "config": "Release"
      }
    }
  }
}
